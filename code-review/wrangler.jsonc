{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "code-review",
  "main": "src/app.ts",
  "compatibility_date": "2025-05-06",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "limits": { "subrequests": 1000000 },
  "vars": {
    "GATEWAY_URL": "https://code-review.clawrence121.workers.dev"
  },
  "kv_namespaces": [
    {
      "binding": "GATEWAY_KV",
      "id": "63cba163110c4dec9735e727edd6a26b"
    }
  ],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "standard-3"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "workflows": [
    {
      "name": "review-workflow",
      "binding": "REVIEW_WORKFLOW",
      "class_name": "ReviewWorkflow"
    }
  ],
  "migrations": [
    {
      "new_sqlite_classes": ["Sandbox"],
      "tag": "v1"
    }
  ]
}
